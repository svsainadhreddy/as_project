<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/sai4"
    android:padding="16dp">

    <!-- Back Button -->


    <!-- Title -->

    <!-- Add Patient -->

    <!-- View Patient -->

    <!-- Edit Patients -->

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_margin="16dp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/circle_dark_bg"
        android:contentDescription="Back"
        android:src="@drawable/ic_arrow_back" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="289dp"
        android:layout_height="42dp"
        android:layout_alignTop="@+id/btnBack"
        android:layout_alignBottom="@+id/btnBack"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="2dp"
        android:width="300dp"
        android:height="40dp"
        android:background="@color/purple_200"
        android:gravity="center"
        android:text="Patient Management"
        android:textColor="@android:color/black"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnAddPatient"
        android:layout_width="221dp"
        android:layout_height="114dp"
        android:layout_below="@id/tvTitle"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="99dp"
        android:layout_marginTop="67dp"
        android:layout_marginEnd="75dp"
        android:background="@drawable/rounded_button"
        android:text="ADD PATIENT"
        android:textColor="@color/black"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnViewPatient"
        android:layout_width="228dp"
        android:layout_height="110dp"
        android:layout_below="@id/btnAddPatient"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="99dp"
        android:layout_marginTop="76dp"
        android:layout_marginEnd="68dp"
        android:background="@drawable/rounded_button"
        android:text="VIEW PATIENT"
        android:textColor="@color/black"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnEditPatient"
        android:layout_width="228dp"
        android:layout_height="128dp"
        android:layout_below="@id/btnViewPatient"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="105dp"
        android:layout_marginTop="76dp"
        android:layout_marginEnd="62dp"
        android:layout_marginBottom="75dp"
        android:background="@drawable/rounded_button"
        android:text="EDIT PATIENTS"
        android:textColor="@color/black"
        android:textSize="18sp" />

</RelativeLayout>
