<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/sai4"
    android:padding="16dp">

    <!-- Back Button -->


    <!-- Title -->

    <!-- Add Patient -->

    <!-- View Patient -->

    <!-- Edit Patients -->

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_margin="16dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="47dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/circle_dark_bg"
        android:contentDescription="Back"
        android:src="@drawable/ic_arrow_back" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="274dp"
        android:layout_height="53dp"
        android:layout_alignTop="@+id/btnBack"
        android:layout_alignBottom="@+id/btnBack"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="-1dp"
        android:layout_marginEnd="13dp"
        android:layout_marginBottom="-4dp"
        android:width="300dp"
        android:height="40dp"
        android:background="@drawable/rounded_button"
        android:gravity="center"
        android:text="Patient Management"
        android:textColor="@android:color/black"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnAddPatient"
        android:layout_width="219dp"
        android:layout_height="100dp"
        android:layout_below="@id/tvTitle"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="101dp"
        android:layout_marginTop="103dp"
        android:layout_marginEnd="75dp"
        android:background="@drawable/rounded_button"
        android:text="ADD PATIENT"
        android:textColor="@color/black"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnViewPatient"
        android:layout_width="217dp"
        android:layout_height="110dp"
        android:layout_below="@id/btnAddPatient"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="102dp"
        android:layout_marginTop="81dp"
        android:layout_marginEnd="76dp"
        android:background="@drawable/rounded_button"
        android:text="VIEW PATIENT"
        android:textColor="@color/black"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnEditPatient"
        android:layout_width="207dp"
        android:layout_height="115dp"
        android:layout_below="@id/btnViewPatient"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="102dp"
        android:layout_marginTop="94dp"
        android:layout_marginEnd="76dp"
        android:layout_marginBottom="186dp"
        android:background="@drawable/rounded_button"
        android:text="EDIT PATIENTS"
        android:textColor="@color/black"
        android:textSize="18sp" />

</RelativeLayout>
